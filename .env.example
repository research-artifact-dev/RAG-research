# SAP AI Core Configuration
# Copy this file to .env and fill in your credentials

# ==============================================
# OPTION 1: Complete Service Key JSON (RECOMMENDED)
# ==============================================
# Paste your entire service key JSON from BTP Cockpit on ONE line

AICORE_SERVICE_KEY={"serviceurls":{"AI_API_URL":"https://api.ai.intprod-eu12.eu-central-1.aws.ml.hana.ondemand.com"},"appname":"1d9c9e6d-b24d-407b-9cf8-22060ec7c6e0!b1288109|xsuaa_std!b318061","clientid":"sb-1d9c9e6d-b24d-407b-9cf8-22060ec7c6e0!b1288109|xsuaa_std!b318061","clientsecret":"7f7fe575-733e-42e3-aeef-d9e2605e94e3$xQw78A2G94fHyilh6uDUDjxIBhfP2s2JXD5NwDbO97Y=","identityzone":"joule-studio-2lqp7feh","identityzoneid":"98592357-2524-4402-834b-24dc7db517cd","url":"https://joule-studio-2lqp7feh.authentication.eu12.hana.ondemand.com","credential-type":"binding-secret"}

# Optional: Override resource group (default is "default")
AICORE_RESOURCE_GROUP=default

# ==============================================
# IMPORTANT: Get Deployment ID from SAP AI Launchpad
# ==============================================
# Go to: AI Launchpad → ML Operations → Deployments
# Find your "gpt-5.3-codex" deployment
# Copy the Deployment ID and paste it below:

AICORE_DEPLOYMENT_ID=your-deployment-id-here

# ==============================================
# Instructions:
# ==============================================
# 1. Copy this file: cp .env.example .env
# 2. Your credentials are already filled in above
# 3. Get the AICORE_DEPLOYMENT_ID from SAP AI Launchpad
# 4. Make sure AICORE_SERVICE_KEY is on ONE line (no newlines)
# 5. Save the file
# 6. The .env file is gitignored (won't be committed)

