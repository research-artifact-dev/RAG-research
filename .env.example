# SAP AI Core Configuration
# Copy this file to .env and fill in your credentials

# ==============================================
# OPTION 1: Complete Service Key JSON (RECOMMENDED)
# ==============================================
# Paste your entire service key JSON from BTP Cockpit on ONE line

AICORE_SERVICE_KEY=""

# Optional: Override resource group (default is "default")
AICORE_RESOURCE_GROUP=default

# ==============================================
# IMPORTANT: Get Deployment ID from SAP AI Launchpad
# ==============================================
# Go to: AI Launchpad → ML Operations → Deployments
# Find your "gpt-5.3-codex" deployment
# Copy the Deployment ID and paste it below:

AICORE_DEPLOYMENT_ID=your-deployment-id-here

# ==============================================
# Instructions:
# ==============================================
# 1. Copy this file: cp .env.example .env
# 2. Your credentials are already filled in above
# 3. Get the AICORE_DEPLOYMENT_ID from SAP AI Launchpad
# 4. Make sure AICORE_SERVICE_KEY is on ONE line (no newlines)
# 5. Save the file
# 6. The .env file is gitignored (won't be committed)

